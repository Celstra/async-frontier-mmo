{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"smoke:browser:install": "playwright install chromium",
		"smoke:browser": "playwright test --project=chromium --project=mobile",
		"smoke:browser:path": "node scripts/require-database-url.mjs && playwright test --project=chromium-path",
		"smoke:browser:gate": "node scripts/require-database-url.mjs && playwright test",
		"smoke:domain": "pnpm --filter @async-frontier-mmo/domain test -- firstSessionGate"
	},
	"dependencies": {
		"@async-frontier-mmo/db": "workspace:*",
		"@async-frontier-mmo/domain": "workspace:*",
		"shared": "workspace:*"
	},
	"devDependencies": {
		"@playwright/test": "^1.55.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.9.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	}
}
